<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mark Angelou Banatasa | IT Portfolio</title>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent: #38bdf8; /* Modern Professional Blue */
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            line-height: 1.6;
            transition: background-color 0.4s ease;
        }

        /* Sticky Nav */
        nav {
            background: rgba(15, 23, 42, 0.8);
            padding: 1.5rem;
            position: sticky;
            top: 0;
            display: flex;
            justify-content: center;
            gap: 30px;
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid #334155;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: color 0.3s;
        }

        nav a:hover { color: var(--accent); }

        /* Container */
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }

        /* Hero */
        .hero { text-align: center; padding: 80px 0; }
        .hero h1 { font-size: 3.5rem; margin-bottom: 0.5rem; }
        .hero p { color: var(--accent); font-size: 1.25rem; font-weight: 500; }

        /* Section Cards */
        .section {
            background: var(--card-bg);
            padding: 3rem;
            margin-bottom: 2rem;
            border-radius: 16px;
            border: 1px solid #334155;
        }

        h2 { border-left: 4px solid var(--accent); padding-left: 15px; margin-bottom: 1.5rem; }

        /* Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        img, video {
            width: 100%;
            height: 200px;0
            object-fit: cover;
            border-radius: 8px;
            transition: transform 0.3s ease;
        }
        
        img:hover, video:hover { transform: scale(1.02); }

        /* Forms */
        input, textarea {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            background: #0f172a;
            border: 1px solid #334155;
            color: white;
            border-radius: 6px;
        }

        .btn {
            padding: 12px 30px;
            background: var(--accent);
            color: #000;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.3s;
        }
        .btn:hover { opacity: 0.9; }

        footer { text-align: center; padding: 40px; color: var(--text-muted); }
    </style>
</head>
